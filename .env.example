# Psychiatrist environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── LLM (Ollama) ──────────────────────────────────────────────────────────────
# Base URL for the local Ollama server (default: http://localhost:11434)
OLLAMA_HOST=http://localhost:11434

# Model to use for care-plan generation and Safety-Critic LLM verifier
# Pull with: ollama pull llama3.2
OLLAMA_MODEL=llama3.2

# ── FastAPI serving ────────────────────────────────────────────────────────────
# Requests per minute per IP on the /analyze endpoint (default: 10)
RATE_LIMIT_RPM=10

# ── MLflow experiment tracking ─────────────────────────────────────────────────
# Set to a remote MLflow server URI for team tracking; leave unset for local
# MLFLOW_TRACKING_URI=http://localhost:5000

# ── DVC remote storage ────────────────────────────────────────────────────────
# Only needed if you configure a DVC remote for data versioning
# DVC_REMOTE_URL=s3://your-bucket/psychiatrist-data

# ── PubMed RAG ────────────────────────────────────────────────────────────────
# Optional NCBI API key for higher rate limits on rag/ingest_pubmed.py
# Without this key, PubMed requests are capped at 3/sec
# NCBI_API_KEY=your_key_here
